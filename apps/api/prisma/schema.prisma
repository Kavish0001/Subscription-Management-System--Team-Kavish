generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  internal_user
  portal_user
}

enum AddressType {
  billing
  shipping
  other
}

enum ProductType {
  goods
  service
}

enum IntervalUnit {
  day
  week
  month
  year
}

enum DiscountType {
  fixed
  percentage
}

enum DiscountScopeType {
  all_products
  selected_products
  subscriptions
}

enum TaxComputation {
  fixed
  percentage
}

enum SubscriptionStatus {
  draft
  quotation
  quotation_sent
  confirmed
  in_progress
  churned
  active
  paused
  closed
  cancelled
}

enum InvoiceStatus {
  draft
  confirmed
  cancelled
  paid
}

enum PaymentStatus {
  pending
  succeeded
  failed
}

enum RelationType {
  renewal
  upsell
}

enum SourceChannel {
  admin
  portal
}

model User {
  id                     String              @id @default(uuid()) @db.Uuid
  email                  String              @unique
  passwordHash           String              @map("password_hash")
  name                   String?
  phone                  String?
  address                String?
  defaultContactId       String?             @unique @db.Uuid @map("default_contact_id")
  role                   UserRole
  isActive               Boolean             @default(true) @map("is_active")
  lastLoginAt            DateTime?           @map("last_login_at")
  emailVerifiedAt        DateTime?           @map("email_verified_at")
  verificationCode       String?             @map("verification_code")
  verificationExpiresAt DateTime?           @map("verification_expires_at")
  resetPasswordTokenHash String?             @map("reset_password_token_hash")
  resetPasswordExpiresAt DateTime?           @map("reset_password_expires_at")
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")
  contacts               Contact[]           @relation("UserContacts")
  defaultContact         Contact?            @relation("UserDefaultContact", fields: [defaultContactId], references: [id], onDelete: SetNull)
  createdContacts        Contact[]           @relation("ContactCreatedBy")
  refreshTokens          RefreshToken[]
  managedSubscriptions   SubscriptionOrder[] @relation("SalespersonSubscriptions")
  createdDiscountRules   DiscountRule[]
  notifications          Notification[]
  auditLogs              AuditLog[]

  @@index([role, isActive])
  @@index([defaultContactId])
  @@map("users")
}

model Contact {
  id            String              @id @default(uuid()) @db.Uuid
  userId        String?             @db.Uuid @map("user_id")
  email         String?
  name          String
  phone         String?
  address       String?
  companyName   String?             @map("company_name")
  notes         String?
  createdById   String?             @db.Uuid @map("created_by")
  isDefault     Boolean             @default(false) @map("is_default")
  isActive      Boolean             @default(true) @map("is_active")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  user          User?               @relation("UserContacts", fields: [userId], references: [id], onDelete: SetNull)
  createdBy     User?               @relation("ContactCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  defaultForUsers User[]            @relation("UserDefaultContact")
  addresses     Address[]
  subscriptions SubscriptionOrder[]
  invoices      Invoice[]

  @@index([userId])
  @@index([createdById])
  @@map("contacts")
}

model Address {
  id         String      @id @default(uuid()) @db.Uuid
  contactId  String      @db.Uuid @map("contact_id")
  type       AddressType
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String      @map("postal_code")
  country    String
  isDefault  Boolean     @default(false) @map("is_default")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  contact    Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId, type])
  @@map("addresses")
}

model ProductCategory {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  slug        String    @unique
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  products    Product[]

  @@map("product_categories")
}

model Product {
  id                    String                  @id @default(uuid()) @db.Uuid
  categoryId            String?                 @db.Uuid @map("category_id")
  name                  String
  slug                  String                  @unique
  description           String?
  productType           ProductType             @map("product_type")
  baseSalesPrice        Decimal                 @db.Decimal(12, 2) @map("base_sales_price")
  costPrice             Decimal                 @db.Decimal(12, 2) @map("cost_price")
  isSubscriptionEnabled Boolean                 @default(true) @map("is_subscription_enabled")
  isActive              Boolean                 @default(true) @map("is_active")
  imageUrl              String?                 @map("image_url")
  imageUrls             String[]                @default([]) @map("image_urls")
  createdAt             DateTime                @default(now()) @map("created_at")
  updatedAt             DateTime                @updatedAt @map("updated_at")
  category              ProductCategory?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  variants              ProductVariant[]
  planPricing           ProductPlanPricing[]
  quotationTemplateLines QuotationTemplateLine[]
  discountRuleProducts  DiscountRuleProduct[]
  productTaxRules       ProductTaxRule[]
  subscriptionLines     SubscriptionOrderLine[]

  @@index([categoryId])
  @@index([productType, isActive])
  @@map("products")
}

model ProductAttribute {
  id          String                  @id @default(uuid()) @db.Uuid
  name        String
  description String?
  isActive    Boolean                 @default(true) @map("is_active")
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")
  values      ProductAttributeValue[]

  @@map("product_attributes")
}

model ProductAttributeValue {
  id            String                @id @default(uuid()) @db.Uuid
  attributeId   String                @db.Uuid @map("attribute_id")
  value         String
  extraPrice    Decimal               @default(0) @db.Decimal(12, 2) @map("extra_price")
  isActive      Boolean               @default(true) @map("is_active")
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")
  attribute     ProductAttribute      @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  variantValues ProductVariantValue[]

  @@unique([attributeId, value])
  @@map("product_attribute_values")
}

model ProductVariant {
  id                     String                @id @default(uuid()) @db.Uuid
  productId              String                @db.Uuid @map("product_id")
  sku                    String?
  name                   String
  priceOverride          Decimal?              @db.Decimal(12, 2) @map("price_override")
  isActive               Boolean               @default(true) @map("is_active")
  createdAt              DateTime              @default(now()) @map("created_at")
  updatedAt              DateTime              @updatedAt @map("updated_at")
  product                Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantValues          ProductVariantValue[]
  quotationTemplateLines QuotationTemplateLine[]
  subscriptionLines      SubscriptionOrderLine[]

  @@map("product_variants")
}

model ProductVariantValue {
  id               String                @id @default(uuid()) @db.Uuid
  variantId        String                @db.Uuid @map("variant_id")
  attributeValueId String                @db.Uuid @map("attribute_value_id")
  createdAt        DateTime              @default(now()) @map("created_at")
  variant          ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attributeValue   ProductAttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@unique([variantId, attributeValueId])
  @@map("product_variant_values")
}

model RecurringPlan {
  id                  String               @id @default(uuid()) @db.Uuid
  name                String
  intervalCount       Int                  @map("interval_count")
  intervalUnit        IntervalUnit         @map("interval_unit")
  price               Decimal              @db.Decimal(12, 2)
  minimumQuantity     Int                  @default(1) @map("minimum_quantity")
  startDate           DateTime?            @map("start_date")
  endDate             DateTime?            @map("end_date")
  autoCloseEnabled    Boolean              @default(false) @map("auto_close_enabled")
  autoCloseAfterCount Int?                 @map("auto_close_after_count")
  autoCloseAfterUnit  IntervalUnit?        @map("auto_close_after_unit")
  isClosable          Boolean              @default(true) @map("is_closable")
  isPausable          Boolean              @default(true) @map("is_pausable")
  isRenewable         Boolean              @default(true) @map("is_renewable")
  isActive            Boolean              @default(true) @map("is_active")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  productPricing      ProductPlanPricing[]
  quotationTemplates  QuotationTemplate[]
  subscriptions       SubscriptionOrder[]

  @@index([isActive])
  @@index([intervalUnit, intervalCount])
  @@map("recurring_plans")
}

model PaymentTerm {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  dueDays     Int      @default(0) @map("due_days")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("payment_terms")
}

model ProductPlanPricing {
  id              String        @id @default(uuid()) @db.Uuid
  productId       String        @db.Uuid @map("product_id")
  recurringPlanId String        @db.Uuid @map("recurring_plan_id")
  overridePrice   Decimal?      @db.Decimal(12, 2) @map("override_price")
  isDefaultPlan   Boolean       @default(false) @map("is_default_plan")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  recurringPlan   RecurringPlan @relation(fields: [recurringPlanId], references: [id], onDelete: Cascade)

  @@unique([productId, recurringPlanId])
  @@map("product_plan_pricing")
}

model QuotationTemplate {
  id               String                  @id @default(uuid()) @db.Uuid
  name             String
  validityDays     Int                     @map("validity_days")
  recurringPlanId  String?                 @db.Uuid @map("recurring_plan_id")
  isLastForever    Boolean                 @default(false) @map("is_last_forever")
  durationCount    Int?                    @map("duration_count")
  durationUnit     IntervalUnit?           @map("duration_unit")
  paymentTermLabel String                  @map("payment_term_label")
  description      String?
  isActive         Boolean                 @default(true) @map("is_active")
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")
  recurringPlan    RecurringPlan?          @relation(fields: [recurringPlanId], references: [id], onDelete: SetNull)
  lines            QuotationTemplateLine[]
  subscriptions    SubscriptionOrder[]

  @@map("quotation_templates")
}

model QuotationTemplateLine {
  id                  String            @id @default(uuid()) @db.Uuid
  quotationTemplateId String            @db.Uuid @map("quotation_template_id")
  productId           String            @db.Uuid @map("product_id")
  variantId           String?           @db.Uuid @map("variant_id")
  quantity            Int
  unitPrice           Decimal           @db.Decimal(12, 2) @map("unit_price")
  sortOrder           Int               @default(0) @map("sort_order")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  quotationTemplate   QuotationTemplate @relation(fields: [quotationTemplateId], references: [id], onDelete: Cascade)
  product             Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant             ProductVariant?   @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@map("quotation_template_lines")
}

model DiscountRule {
  id                String              @id @default(uuid()) @db.Uuid
  name              String
  code              String?             @unique
  discountType      DiscountType        @map("discount_type")
  value             Decimal             @db.Decimal(12, 2)
  minimumPurchase   Decimal?            @db.Decimal(12, 2) @map("minimum_purchase")
  minimumQuantity   Int?                @map("minimum_quantity")
  startDate         DateTime?           @map("start_date")
  endDate           DateTime?           @map("end_date")
  limitUsageEnabled Boolean             @default(false) @map("limit_usage_enabled")
  usageLimit        Int?                @map("usage_limit")
  usageCount        Int                 @default(0) @map("usage_count")
  scopeType         DiscountScopeType   @map("scope_type")
  createdById       String              @db.Uuid @map("created_by")
  isActive          Boolean             @default(true) @map("is_active")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  createdBy         User                @relation(fields: [createdById], references: [id], onDelete: Restrict)
  products          DiscountRuleProduct[]

  @@map("discount_rules")
}

model DiscountRuleProduct {
  id             String       @id @default(uuid()) @db.Uuid
  discountRuleId String       @db.Uuid @map("discount_rule_id")
  productId      String       @db.Uuid @map("product_id")
  discountRule   DiscountRule @relation(fields: [discountRuleId], references: [id], onDelete: Cascade)
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([discountRuleId, productId])
  @@map("discount_rule_products")
}

model TaxRule {
  id          String                    @id @default(uuid()) @db.Uuid
  name        String
  ratePercent Decimal                   @db.Decimal(5, 2) @map("rate_percent")
  computation TaxComputation           @default(percentage)
  taxType     String                    @map("tax_type")
  isInclusive Boolean                   @default(false) @map("is_inclusive")
  isActive    Boolean                   @default(true) @map("is_active")
  createdAt   DateTime                  @default(now()) @map("created_at")
  updatedAt   DateTime                  @updatedAt @map("updated_at")
  products    ProductTaxRule[]
  lineTaxes   SubscriptionOrderLineTax[]

  @@map("tax_rules")
}

model ProductTaxRule {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @db.Uuid @map("product_id")
  taxRuleId String   @db.Uuid @map("tax_rule_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  taxRule   TaxRule  @relation(fields: [taxRuleId], references: [id], onDelete: Cascade)

  @@unique([productId, taxRuleId])
  @@map("product_tax_rules")
}

model SubscriptionOrder {
  id                 String                  @id @default(uuid()) @db.Uuid
  subscriptionNumber String                  @unique @map("subscription_number")
  customerContactId  String                  @db.Uuid @map("customer_contact_id")
  salespersonUserId  String                  @db.Uuid @map("salesperson_user_id")
  quotationTemplateId String?                @db.Uuid @map("quotation_template_id")
  recurringPlanId    String?                 @db.Uuid @map("recurring_plan_id")
  parentOrderId      String?                 @db.Uuid @map("parent_order_id")
  relationType       RelationType?           @map("relation_type")
  sourceChannel      SourceChannel           @map("source_channel")
  status             SubscriptionStatus      @default(draft)
  quotationDate      DateTime?               @map("quotation_date")
  quotationExpiresAt DateTime?               @map("quotation_expires_at")
  confirmedAt        DateTime?               @map("confirmed_at")
  startDate          DateTime?               @map("start_date")
  nextInvoiceDate    DateTime?               @map("next_invoice_date")
  expirationDate     DateTime?               @map("expiration_date")
  paymentTermLabel   String?                 @map("payment_term_label")
  currencyCode       String                  @default("INR") @map("currency_code")
  subtotalAmount     Decimal                 @default(0) @db.Decimal(12, 2) @map("subtotal_amount")
  discountAmount     Decimal                 @default(0) @db.Decimal(12, 2) @map("discount_amount")
  taxAmount          Decimal                 @default(0) @db.Decimal(12, 2) @map("tax_amount")
  totalAmount        Decimal                 @default(0) @db.Decimal(12, 2) @map("total_amount")
  renewalCount       Int                     @default(0) @map("renewal_count")
  upsellCount        Int                     @default(0) @map("upsell_count")
  notes              String?
  createdAt          DateTime                @default(now()) @map("created_at")
  updatedAt          DateTime                @updatedAt @map("updated_at")
  customerContact    Contact                 @relation(fields: [customerContactId], references: [id], onDelete: Restrict)
  salesperson        User                    @relation("SalespersonSubscriptions", fields: [salespersonUserId], references: [id], onDelete: Restrict)
  quotationTemplate  QuotationTemplate?      @relation(fields: [quotationTemplateId], references: [id], onDelete: SetNull)
  recurringPlan      RecurringPlan?          @relation(fields: [recurringPlanId], references: [id], onDelete: SetNull)
  parentOrder        SubscriptionOrder?      @relation("SubscriptionOrderRelations", fields: [parentOrderId], references: [id], onDelete: SetNull)
  childOrders        SubscriptionOrder[]     @relation("SubscriptionOrderRelations")
  lines              SubscriptionOrderLine[]
  invoices           Invoice[]

  @@index([customerContactId])
  @@index([salespersonUserId])
  @@index([status])
  @@index([startDate, nextInvoiceDate, expirationDate])
  @@index([parentOrderId, relationType])
  @@map("subscription_orders")
}

model SubscriptionOrderLine {
  id                  String                    @id @default(uuid()) @db.Uuid
  subscriptionOrderId String                    @db.Uuid @map("subscription_order_id")
  productId           String                    @db.Uuid @map("product_id")
  variantId           String?                   @db.Uuid @map("variant_id")
  productNameSnapshot String                    @map("product_name_snapshot")
  quantity            Int
  unitPrice           Decimal                   @db.Decimal(12, 2) @map("unit_price")
  discountAmount      Decimal                   @default(0) @db.Decimal(12, 2) @map("discount_amount")
  taxAmount           Decimal                   @default(0) @db.Decimal(12, 2) @map("tax_amount")
  lineTotal           Decimal                   @db.Decimal(12, 2) @map("line_total")
  sortOrder           Int                       @default(0) @map("sort_order")
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @updatedAt @map("updated_at")
  subscriptionOrder   SubscriptionOrder         @relation(fields: [subscriptionOrderId], references: [id], onDelete: Cascade)
  product             Product                   @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant             ProductVariant?           @relation(fields: [variantId], references: [id], onDelete: SetNull)
  taxes               SubscriptionOrderLineTax[]
  invoiceLines        InvoiceLine[]

  @@map("subscription_order_lines")
}

model SubscriptionOrderLineTax {
  id                      String                @id @default(uuid()) @db.Uuid
  subscriptionOrderLineId String                @db.Uuid @map("subscription_order_line_id")
  taxRuleId               String                @db.Uuid @map("tax_rule_id")
  taxRateSnapshot         Decimal               @db.Decimal(5, 2) @map("tax_rate_snapshot")
  taxAmount               Decimal               @db.Decimal(12, 2) @map("tax_amount")
  line                    SubscriptionOrderLine @relation(fields: [subscriptionOrderLineId], references: [id], onDelete: Cascade)
  taxRule                 TaxRule               @relation(fields: [taxRuleId], references: [id], onDelete: Restrict)

  @@map("subscription_order_line_taxes")
}

model Invoice {
  id                  String            @id @default(uuid()) @db.Uuid
  invoiceNumber       String            @unique @map("invoice_number")
  subscriptionOrderId String            @db.Uuid @map("subscription_order_id")
  customerContactId   String            @db.Uuid @map("customer_contact_id")
  status              InvoiceStatus     @default(draft)
  invoiceDate         DateTime          @map("invoice_date")
  dueDate             DateTime          @map("due_date")
  sourceLabel         String            @map("source_label")
  paymentTermLabel    String?           @map("payment_term_label")
  currencyCode        String            @default("INR") @map("currency_code")
  subtotalAmount      Decimal           @default(0) @db.Decimal(12, 2) @map("subtotal_amount")
  discountAmount      Decimal           @default(0) @db.Decimal(12, 2) @map("discount_amount")
  taxAmount           Decimal           @default(0) @db.Decimal(12, 2) @map("tax_amount")
  totalAmount         Decimal           @default(0) @db.Decimal(12, 2) @map("total_amount")
  paidAmount          Decimal           @default(0) @db.Decimal(12, 2) @map("paid_amount")
  amountDue           Decimal           @default(0) @db.Decimal(12, 2) @map("amount_due")
  cancelledAt         DateTime?         @map("cancelled_at")
  paidAt              DateTime?         @map("paid_at")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  subscriptionOrder   SubscriptionOrder @relation(fields: [subscriptionOrderId], references: [id], onDelete: Restrict)
  customerContact     Contact           @relation(fields: [customerContactId], references: [id], onDelete: Restrict)
  lines               InvoiceLine[]
  payments            Payment[]

  @@index([subscriptionOrderId])
  @@index([customerContactId])
  @@index([status, dueDate])
  @@map("invoices")
}

model InvoiceLine {
  id                      String                 @id @default(uuid()) @db.Uuid
  invoiceId               String                 @db.Uuid @map("invoice_id")
  subscriptionOrderLineId String?                @db.Uuid @map("subscription_order_line_id")
  productNameSnapshot     String                 @map("product_name_snapshot")
  quantity                Int
  unitPrice               Decimal                @db.Decimal(12, 2) @map("unit_price")
  discountAmount          Decimal                @default(0) @db.Decimal(12, 2) @map("discount_amount")
  taxAmount               Decimal                @default(0) @db.Decimal(12, 2) @map("tax_amount")
  lineTotal               Decimal                @db.Decimal(12, 2) @map("line_total")
  sortOrder               Int                    @default(0) @map("sort_order")
  invoice                 Invoice                @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  subscriptionOrderLine   SubscriptionOrderLine? @relation(fields: [subscriptionOrderLineId], references: [id], onDelete: SetNull)

  @@map("invoice_lines")
}

model Payment {
  id                    String        @id @default(uuid()) @db.Uuid
  invoiceId             String        @db.Uuid @map("invoice_id")
  paymentReference      String        @unique @map("payment_reference")
  paymentMethod         String        @map("payment_method")
  provider              String
  status                PaymentStatus @default(pending)
  amount                Decimal       @db.Decimal(12, 2)
  currencyCode          String        @default("INR") @map("currency_code")
  providerTransactionId String?       @map("provider_transaction_id")
  paidAt                DateTime?     @map("paid_at")
  failureReason         String?       @map("failure_reason")
  metadataJson          Json?         @map("metadata_json")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")
  invoice               Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  @@index([invoiceId])
  @@index([status, paidAt])
  @@map("payments")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid @map("user_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Job {
  id            String    @id @default(uuid()) @db.Uuid
  jobType       String    @map("job_type")
  status        String
  referenceType String    @map("reference_type")
  referenceId   String    @map("reference_id")
  scheduledFor  DateTime  @map("scheduled_for")
  processedAt   DateTime? @map("processed_at")
  payloadJson   Json?     @map("payload_json")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("jobs")
}

model Notification {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String?   @db.Uuid @map("user_id")
  channel       String
  templateKey   String    @map("template_key")
  status        String
  referenceType String    @map("reference_type")
  referenceId   String    @map("reference_id")
  sentAt        DateTime? @map("sent_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("notifications")
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  actorUserId   String?  @db.Uuid @map("actor_user_id")
  entityType    String   @map("entity_type")
  entityId      String   @map("entity_id")
  action        String
  oldValuesJson Json?    @map("old_values_json")
  newValuesJson Json?    @map("new_values_json")
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  createdAt     DateTime @default(now()) @map("created_at")
  actorUser     User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
